# ========================================
# 沖ダイブ・パートナー 環境変数
# cp .env.local.example .env.local して値を記入
# ========================================

# ── スタッフ認証（必須）──────────────────────────────────
# 書式: "メール:パスワード|メール2:パスワード2"
STAFF_CREDENTIALS=staff@okidive.com:your_password

# JWT 署名キー（必須）— ランダムな長い文字列を指定
# 生成例: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_random_32bytes_hex

# ── Google Sheets API（任意）────────────────────────────
# 設定しない場合はモックデータで動作します
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_sa@your_project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id
